# MongoDB connection string (e.g. mongodb+srv://user:pass@cluster.mongodb.net/dbname)
MONGODB_URI=

# Secret used to sign JWTs — use a long random string in production
SECRET_KEY=

# How long JWT tokens remain valid (e.g. 7d, 24h)
TOKEN_EXPIRATION=7d

# Base URL of the application (used for CORS origin restriction in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Prefix for all API requests made from the frontend (must end with /api/)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/

# Cloudinary credentials — required for poster image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
